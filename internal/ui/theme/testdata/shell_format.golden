theme: shell
  primary          = ansi:4
  accent           = ansi:5
  muted            = ansi:8
  success          = ansi:2
  warn             = ansi:3
  error            = ansi:1
  code.bg          = (default)
  code.fg          = ansi:7
  diff.add.bg      = ansi:22
  diff.del.bg      = ansi:52
  statusbar.bg     = ansi:8
  statusbar.fg     = ansi:15
  modal.bg         = (default)
  modal.border     = ansi:8
  bubble.border    = ansi:5
  bubble.border.distinct = ansi:8
  bubble.header    = ansi:5
  bubble.header.muted = ansi:8
  bubble.body.muted = ansi:8
  bubble.user.border = ansi:4
  bubble.agent.border = ansi:5
  sidebar.border   = ansi:8
  sidebar.section  = ansi:8
  sidebar.value    = (default)
  sidebar.accent   = ansi:5
  sidebar.muted    = ansi:8
